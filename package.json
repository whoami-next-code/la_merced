{
  "name": "la-merced-pyk",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema multiplataforma — Multiservicios La Merced PyK S.A.C.",
  "scripts": {
    "dev": "node startup.js",
    "seed:admin": "npm run seed:admin --prefix backend",
    "db:apply": "npm run db:apply --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:admin": "npm run dev --prefix admin",
    "dev:backend": "npm run start:dev --prefix backend",
    "dev:mobile": "cd mobile_app && flutter run -d windows",
    "dev:mobile:chrome": "cd mobile_app && flutter run -d chrome",
    "build:frontend": "npm run build --prefix frontend",
    "build:admin": "npm run build --prefix admin",
    "build:backend": "npm run build --prefix backend",
    "install:all": "npm install --prefix frontend && npm install --prefix admin && npm install --prefix backend"
  },
  "engines": {
    "node": ">=20"
  }
}
